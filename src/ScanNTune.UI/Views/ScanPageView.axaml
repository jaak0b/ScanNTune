<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScanNTune.UI.ViewModels"
             xmlns:ctrl="using:ScanNTune.UI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
             x:Class="ScanNTune.UI.Views.ScanPageView"
             x:DataType="vm:ScanPageViewModel">

    <UserControl.Resources>
        <!-- Upload arrow over a tray: the icon on the button that opens the file picker. -->
        <StreamGeometry x:Key="UploadIcon">M12 4 L6 10 H10 V15 H14 V10 H18 Z M6 18 H18 V20 H6 Z</StreamGeometry>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.step">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style Selector="TextBlock.h4">
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBlock.tip">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style Selector="Border.slot">
            <Setter Property="Height" Value="215"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <!-- The small "Choose file" / "Replace" button inside a slot: it opens the picker on press. Being a
             small target, the rest of the slot stays free so a drag there scrolls the page instead of opening. -->
        <Style Selector="Border.uploadBtn">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.uploadBtn:pointerover">
            <Setter Property="Opacity" Value="0.88"/>
        </Style>

        <!-- The connector arrow points right between the side-by-side slots; when the layout folds to a
             stack (narrow window or phone) it turns to point down. -->
        <Style Selector="ctrl|ResponsiveStack:stacked TextBlock.connArrow">
            <Setter Property="RenderTransform" Value="rotate(90deg)"/>
        </Style>
        <Style Selector="Rectangle.outlineEmpty">
            <Setter Property="RadiusX" Value="12"/>
            <Setter Property="RadiusY" Value="12"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
            <Setter Property="StrokeDashArray" Value="4,3"/>
            <Setter Property="Stroke" Value="{DynamicResource BorderStrongBrush}"/>
        </Style>
        <Style Selector="Rectangle.outlineFilled">
            <Setter Property="RadiusX" Value="12"/>
            <Setter Property="RadiusY" Value="12"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Stroke" Value="{DynamicResource BorderBrush}"/>
        </Style>
        <Style Selector="Rectangle.outlineError">
            <Setter Property="RadiusX" Value="12"/>
            <Setter Property="RadiusY" Value="12"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
            <Setter Property="Stroke" Value="{DynamicResource WarningBrush}"/>
        </Style>
        <Style Selector="TextBlock.slabel">
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="TextBlock.status">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.status.error">
            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
        </Style>
        <Style Selector="TextBlock.ssub">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- On a touch device the numeric fields drop text entry so tapping one cannot raise a soft keyboard or
             leave an uneditable caret; the field's own +/- steppers stay live (they are separate template parts,
             not gated by the inner text box). Toggled by the view model's IsTouchDevice. -->
        <Style Selector="NumericUpDown.touchInput /template/ TextBox">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <!-- Slot 2's coupon rests quarter-turned (90°); while the slot is hovered it replays the turn from
             upright, holding at the start and end so the motion is easy to follow. -->
        <Style Selector="Border#Slot2:pointerover Border.turn">
            <Style.Animations>
                <Animation Duration="0:0:2.6" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0"/></KeyFrame>
                    <KeyFrame Cue="25%"><Setter Property="RotateTransform.Angle" Value="0"/></KeyFrame>
                    <KeyFrame Cue="65%"><Setter Property="RotateTransform.Angle" Value="90"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="90"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="14" MaxWidth="860" HorizontalAlignment="Center">

            <StackPanel Spacing="2">
                <TextBlock Text="Two-scan calibration" FontWeight="Bold" FontSize="18"/>
                <TextBlock Opacity="0.7" TextWrapping="Wrap"
                           Text="Scan the coupon, turn it a quarter-turn, and scan again. Combining the two cancels your scanner's own X/Y stretch and skew."/>
            </StackPanel>

            <!-- 1 · Calibrate scanner -->
            <Border Classes="step">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <TextBlock Text="1" Foreground="{DynamicResource PrimaryBrush}" Classes="h4"/>
                            <TextBlock Text="Calibrate scanner" Classes="h4"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="{Binding CalibrateButtonText}" Command="{Binding CalibrateCommand}"
                                Classes.accent="{Binding !IsCalibrated}" Padding="10,6" FontSize="12.5"/>
                    </Grid>
                    <!-- DockPanel (not a horizontal StackPanel) so the status line wraps instead of clipping on a narrow screen. -->
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="✓" Margin="0,0,7,0"
                                   Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding IsCalibrated}"/>
                        <TextBlock DockPanel.Dock="Left" Text="⚠" Margin="0,0,7,0"
                                   Foreground="{DynamicResource WarningBrush}" IsVisible="{Binding !IsCalibrated}"/>
                        <TextBlock Text="{Binding CalibrationLineText}" Classes="tip"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- 2 · Print the coupon -->
            <Border Classes="step">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <TextBlock Text="2" Foreground="{DynamicResource PrimaryBrush}" Classes="h4"/>
                            <TextBlock Text="Print the coupon" Classes="h4"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Open STL" Click="OnGetCouponPressed" Padding="10,6" FontSize="12.5"
                                BorderBrush="{DynamicResource PrimaryBrush}" Foreground="#B7BDF8"
                                ToolTip.Tip="Copies the 100 mm coupon to a temp folder and lets you pick a program (your slicer) to open it in."/>
                    </Grid>
                    <TextBlock Classes="tip" Text="100 mm model, printed flat. It has to contrast with the scan background, so a white coupon on a white scanner lid will not work; back it with a coloured sheet of paper."/>
                </StackPanel>
            </Border>

            <!-- 3 · Add the two scans -->
            <Border Classes="step">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="3">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <TextBlock Text="3" Foreground="{DynamicResource PrimaryBrush}" Classes="h4"/>
                            <TextBlock Text="Add the two scans" Classes="h4"/>
                        </StackPanel>
                        <TextBlock Classes="tip" Text="{Binding ScanDpiHint}" IsVisible="{Binding IsCalibrated}"/>
                    </StackPanel>

                    <ctrl:ResponsiveStack Breakpoint="520" Spacing="12">

                        <!-- Slot 1 -->
                        <Border x:Name="Slot1" ctrl:ResponsiveStack.Fill="True" Classes="slot" DragDrop.AllowDrop="True">
                            <Panel>
                                <Rectangle Classes="outlineEmpty" IsVisible="{Binding !HasScan1}"/>
                                <Rectangle Classes="outlineFilled" IsVisible="{Binding HasScan1}"/>
                                <Rectangle Classes="outlineError" IsVisible="{Binding Scan1Failed}"/>

                                <!-- Empty -->
                                <DockPanel IsVisible="{Binding !HasScan1}" Margin="12,10">
                                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="slabel" Text="First scan"/>
                                        <TextBlock Grid.Column="1" Classes="ssub" Text="as placed"/>
                                    </Grid>
                                    <StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Center" Spacing="5">
                                        <Border Classes="uploadBtn" HorizontalAlignment="Center" PointerPressed="OnUpload1Pressed">
                                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                                <Path Width="15" Height="15" Stretch="Uniform" Fill="White" Data="{StaticResource UploadIcon}"/>
                                                <TextBlock Text="Choose file" Foreground="White" FontSize="13" FontWeight="Medium"/>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="or drop here" HorizontalAlignment="Center" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <ctrl:CouponGlyph Width="80" Height="80"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DockPanel>

                                <!-- Filled -->
                                <DockPanel IsVisible="{Binding HasScan1}" Margin="12,10">
                                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="slabel" Text="First scan"/>
                                        <TextBlock Grid.Column="1" Classes="ssub" Text="as placed"/>
                                    </Grid>
                                    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                                        <TextBlock Grid.Column="1" Text="{Binding Scan1Caption}" FontSize="12"
                                                   IsVisible="{Binding !Scan1Failed}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="6,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Scan1Note}" FontSize="12"
                                                   IsVisible="{Binding Scan1Failed}"
                                                   Foreground="{DynamicResource WarningBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="6,0"/>
                                        <Border Grid.Column="2" Classes="uploadBtn" Padding="8,5" PointerPressed="OnUpload1Pressed">
                                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                <Path Width="12" Height="12" Stretch="Uniform" Fill="White" Data="{StaticResource UploadIcon}"/>
                                                <TextBlock Text="Replace" Foreground="White" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <Image Source="{Binding Scan1Thumb}" Stretch="Uniform" Margin="0,8"/>
                                </DockPanel>

                                <!-- Decode of a large photo blocks the single wasm thread; cover the slot while it runs. -->
                                <Panel IsVisible="{Binding Scan1Loading}" Background="#88000000">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                        <ProgressBar IsIndeterminate="True" Width="120" Height="4"/>
                                        <TextBlock Text="Loading…" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                </Panel>
                            </Panel>
                        </Border>

                        <!-- Connector: points right between side-by-side slots, turns to point down when they stack -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2" Margin="4,0">
                            <TextBlock Classes="connArrow" Text="→" FontSize="26" HorizontalAlignment="Center"
                                       RenderTransformOrigin="50%,50%"
                                       Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text="90°" FontSize="11" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Slot 2 -->
                        <Border x:Name="Slot2" ctrl:ResponsiveStack.Fill="True" Classes="slot" DragDrop.AllowDrop="True">
                            <Panel>
                                <Rectangle Classes="outlineEmpty" IsVisible="{Binding !HasScan2}"/>
                                <Rectangle Classes="outlineFilled" IsVisible="{Binding HasScan2}"/>
                                <Rectangle Classes="outlineError" IsVisible="{Binding Scan2Failed}"/>

                                <!-- Empty -->
                                <DockPanel IsVisible="{Binding !HasScan2}" Margin="12,10">
                                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="slabel" Text="Second scan"/>
                                        <TextBlock Grid.Column="1" Classes="ssub" Text="quarter-turned"/>
                                    </Grid>
                                    <StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Center" Spacing="5">
                                        <Border Classes="uploadBtn" HorizontalAlignment="Center" PointerPressed="OnUpload2Pressed">
                                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                                <Path Width="15" Height="15" Stretch="Uniform" Fill="White" Data="{StaticResource UploadIcon}"/>
                                                <TextBlock Text="Choose file" Foreground="White" FontSize="13" FontWeight="Medium"/>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="or drop here" HorizontalAlignment="Center" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <!-- Pivots about an off-centre point so the coupon sweeps: the 0° start
                                         sits offset to the right, and the turn carries it onto the centred 90°
                                         resting frame. The left Margin shifts the layout right to re-centre 90°. -->
                                    <Border Classes="turn" Width="80" Height="80" Margin="80,0,0,0"
                                            RenderTransformOrigin="25%,25%"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="Transparent">
                                        <Border.RenderTransform>
                                            <RotateTransform Angle="90"/>
                                        </Border.RenderTransform>
                                        <ctrl:CouponGlyph Width="80" Height="80"/>
                                    </Border>
                                </DockPanel>

                                <!-- Filled -->
                                <DockPanel IsVisible="{Binding HasScan2}" Margin="12,10">
                                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="slabel" Text="Second scan"/>
                                        <TextBlock Grid.Column="1" Classes="ssub" Text="quarter-turned"/>
                                    </Grid>
                                    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                                        <TextBlock Grid.Column="1" Text="{Binding Scan2Caption}" FontSize="12"
                                                   IsVisible="{Binding !Scan2Failed}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="6,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Scan2Note}" FontSize="12"
                                                   IsVisible="{Binding Scan2Failed}"
                                                   Foreground="{DynamicResource WarningBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="6,0"/>
                                        <Border Grid.Column="2" Classes="uploadBtn" Padding="8,5" PointerPressed="OnUpload2Pressed">
                                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                <Path Width="12" Height="12" Stretch="Uniform" Fill="White" Data="{StaticResource UploadIcon}"/>
                                                <TextBlock Text="Replace" Foreground="White" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <Image Source="{Binding Scan2Thumb}" Stretch="Uniform" Margin="0,8"/>
                                </DockPanel>

                                <Panel IsVisible="{Binding Scan2Loading}" Background="#88000000">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                        <ProgressBar IsIndeterminate="True" Width="120" Height="4"/>
                                        <TextBlock Text="Loading…" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                </Panel>
                            </Panel>
                        </Border>

                    </ctrl:ResponsiveStack>

                    <!-- Slim settings strip: the steppers wrap to the next line on a narrow screen -->
                    <WrapPanel Margin="2,0,0,0">
                        <StackPanel Spacing="3" Margin="0,0,18,10" IsVisible="{Binding !IsCalibrated}">
                            <TextBlock Text="Scanner DPI" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <NumericUpDown Value="{Binding Dpi}" Increment="100" Minimum="50" FormatString="0" Width="150"
                                           Classes.touchInput="{Binding IsTouchDevice}"
                                           ToolTip.Tip="Pixels-per-mm = DPI ÷ 25.4. Needed for absolute scale; clear it for anisotropy and skew only."/>
                        </StackPanel>
                        <StackPanel Spacing="3" Margin="0,0,18,10">
                            <TextBlock Text="Coupon (mm)" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <NumericUpDown Value="{Binding BaselineMm}" Increment="10" Minimum="10" FormatString="0.##" Width="150"
                                           Classes.touchInput="{Binding IsTouchDevice}"
                                           ToolTip.Tip="Centre-to-centre span of the outermost rings. Default 100."/>
                        </StackPanel>
                        <StackPanel Spacing="3" Margin="0,0,18,10">
                            <TextBlock Text="Rings/side" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <NumericUpDown Value="{Binding Grid}" Increment="1" Minimum="2" FormatString="0" Width="140"
                                           Classes.touchInput="{Binding IsTouchDevice}"
                                           ToolTip.Tip="Rings per side (grid_n in the model). Default 5."/>
                        </StackPanel>
                    </WrapPanel>

                    <Button Content="Analyze both scans" Classes="accent" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" Padding="12,10" FontSize="15"
                            Command="{Binding AnalyzeCommand}"/>
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" Height="4"/>
                    <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" IsVisible="{Binding HasStatus}"
                               Classes="status" Classes.error="{Binding IsError}" HorizontalAlignment="Center"/>

                    <TextBlock TextWrapping="Wrap" FontSize="12" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="The two solid rings mark the coupon's corner. The app uses them to align both scans."/>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

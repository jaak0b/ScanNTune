<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScanNTune.App.ViewModels"
             xmlns:ctrl="using:ScanNTune.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
             x:Class="ScanNTune.App.Views.ScanPageView"
             x:DataType="vm:ScanPageViewModel">

    <UserControl.Styles>
        <Style Selector="Border.step">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style Selector="TextBlock.h4">
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBlock.tip">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style Selector="Border.slot">
            <Setter Property="Height" Value="215"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Rectangle.outlineEmpty">
            <Setter Property="RadiusX" Value="12"/>
            <Setter Property="RadiusY" Value="12"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
            <Setter Property="StrokeDashArray" Value="4,3"/>
            <Setter Property="Stroke" Value="{DynamicResource BorderStrongBrush}"/>
        </Style>
        <Style Selector="Rectangle.outlineFilled">
            <Setter Property="RadiusX" Value="12"/>
            <Setter Property="RadiusY" Value="12"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Stroke" Value="{DynamicResource BorderBrush}"/>
        </Style>
        <Style Selector="Rectangle.outlineError">
            <Setter Property="RadiusX" Value="12"/>
            <Setter Property="RadiusY" Value="12"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
            <Setter Property="Stroke" Value="{DynamicResource WarningBrush}"/>
        </Style>
        <Style Selector="TextBlock.slabel">
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="TextBlock.status">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.status.error">
            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
        </Style>
        <Style Selector="TextBlock.ssub">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Slot 2's coupon sits statically quarter-turned; while the slot is hovered it plays the turn. -->
        <Style Selector="Border#Slot2:pointerover Border.turn">
            <Style.Animations>
                <Animation Duration="0:0:1.7" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0"/></KeyFrame>
                    <KeyFrame Cue="65%"><Setter Property="RotateTransform.Angle" Value="90"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="90"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="14" MaxWidth="860" HorizontalAlignment="Center">

            <StackPanel Spacing="2">
                <TextBlock Text="Two-scan calibration" FontWeight="Bold" FontSize="18"/>
                <TextBlock Opacity="0.7" TextWrapping="Wrap"
                           Text="Scan the coupon, turn it a quarter-turn, and scan again — combining the two cancels your scanner's own X/Y stretch and skew."/>
            </StackPanel>

            <!-- 1 · Calibrate scanner -->
            <Border Classes="step">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <TextBlock Text="1" Foreground="{DynamicResource PrimaryBrush}" Classes="h4"/>
                            <TextBlock Text="Calibrate scanner" Classes="h4"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="{Binding CalibrateButtonText}" Command="{Binding CalibrateCommand}"
                                Classes.accent="{Binding !IsCalibrated}" Padding="10,6" FontSize="12.5"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <TextBlock Text="✓" Foreground="{DynamicResource SuccessBrush}" IsVisible="{Binding IsCalibrated}"/>
                        <TextBlock Text="⚠" Foreground="{DynamicResource WarningBrush}" IsVisible="{Binding !IsCalibrated}"/>
                        <TextBlock Text="{Binding CalibrationLineText}" Classes="tip"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 2 · Print the coupon -->
            <Border Classes="step">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <TextBlock Text="2" Foreground="{DynamicResource PrimaryBrush}" Classes="h4"/>
                            <TextBlock Text="Print the coupon" Classes="h4"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Open STL" Click="OnGetCouponPressed" Padding="10,6" FontSize="12.5"
                                BorderBrush="{DynamicResource PrimaryBrush}" Foreground="#B7BDF8"
                                ToolTip.Tip="Copies the 100 mm coupon to a temp folder and lets you pick a program (your slicer) to open it in."/>
                    </Grid>
                    <TextBlock Classes="tip" Text="100 mm model — opens in your slicer, print it flat."/>
                </StackPanel>
            </Border>

            <!-- 3 · Add the two scans -->
            <Border Classes="step">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <TextBlock Text="3" Foreground="{DynamicResource PrimaryBrush}" Classes="h4"/>
                        <TextBlock Text="Add the two scans" Classes="h4"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,64,*" VerticalAlignment="Center">

                        <!-- Slot 1 -->
                        <Border x:Name="Slot1" Grid.Column="0" Classes="slot" DragDrop.AllowDrop="True"
                                PointerPressed="OnSlot1Pressed">
                            <Panel>
                                <Rectangle Classes="outlineEmpty" IsVisible="{Binding !HasScan1}"/>
                                <Rectangle Classes="outlineFilled" IsVisible="{Binding HasScan1}"/>
                                <Rectangle Classes="outlineError" IsVisible="{Binding Scan1Failed}"/>

                                <!-- Empty -->
                                <DockPanel IsVisible="{Binding !HasScan1}" Margin="12,10">
                                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="slabel" Text="First scan"/>
                                        <TextBlock Grid.Column="1" Classes="ssub" Text="as placed"/>
                                    </Grid>
                                    <TextBlock DockPanel.Dock="Bottom" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryBrush}" FontSize="13"
                                               Text="Choose file or drop here"/>
                                    <ctrl:CouponGlyph Width="80" Height="80"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DockPanel>

                                <!-- Filled -->
                                <DockPanel IsVisible="{Binding HasScan1}" Margin="12,10">
                                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="slabel" Text="First scan"/>
                                        <TextBlock Grid.Column="1" Classes="ssub" Text="as placed"/>
                                    </Grid>
                                    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                                        <TextBlock Grid.Column="1" Text="{Binding Scan1Caption}" FontSize="12"
                                                   IsVisible="{Binding !Scan1Failed}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="6,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Scan1Note}" FontSize="12"
                                                   IsVisible="{Binding Scan1Failed}"
                                                   Foreground="{DynamicResource WarningBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="6,0"/>
                                        <TextBlock Grid.Column="2" Text="Replace" FontSize="12"
                                                   Foreground="{DynamicResource PrimaryBrush}"/>
                                    </Grid>
                                    <Image Source="{Binding Scan1Thumb}" Stretch="Uniform" Margin="0,8"/>
                                </DockPanel>
                            </Panel>
                        </Border>

                        <!-- Connector -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="↻" FontSize="28" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text="90°" FontSize="11" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Slot 2 -->
                        <Border x:Name="Slot2" Grid.Column="2" Classes="slot" DragDrop.AllowDrop="True"
                                PointerPressed="OnSlot2Pressed">
                            <Panel>
                                <Rectangle Classes="outlineEmpty" IsVisible="{Binding !HasScan2}"/>
                                <Rectangle Classes="outlineFilled" IsVisible="{Binding HasScan2}"/>
                                <Rectangle Classes="outlineError" IsVisible="{Binding Scan2Failed}"/>

                                <!-- Empty -->
                                <DockPanel IsVisible="{Binding !HasScan2}" Margin="12,10">
                                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="slabel" Text="Second scan"/>
                                        <TextBlock Grid.Column="1" Classes="ssub" Text="quarter-turned"/>
                                    </Grid>
                                    <TextBlock DockPanel.Dock="Bottom" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryBrush}" FontSize="13"
                                               Text="Choose file or drop here"/>
                                    <Border Classes="turn" RenderTransformOrigin="0.5,0.5"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="Transparent">
                                        <Border.RenderTransform>
                                            <RotateTransform Angle="90"/>
                                        </Border.RenderTransform>
                                        <ctrl:CouponGlyph Width="80" Height="80"/>
                                    </Border>
                                </DockPanel>

                                <!-- Filled -->
                                <DockPanel IsVisible="{Binding HasScan2}" Margin="12,10">
                                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="slabel" Text="Second scan"/>
                                        <TextBlock Grid.Column="1" Classes="ssub" Text="quarter-turned"/>
                                    </Grid>
                                    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                                        <TextBlock Grid.Column="1" Text="{Binding Scan2Caption}" FontSize="12"
                                                   IsVisible="{Binding !Scan2Failed}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="6,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Scan2Note}" FontSize="12"
                                                   IsVisible="{Binding Scan2Failed}"
                                                   Foreground="{DynamicResource WarningBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="6,0"/>
                                        <TextBlock Grid.Column="2" Text="Replace" FontSize="12"
                                                   Foreground="{DynamicResource PrimaryBrush}"/>
                                    </Grid>
                                    <Image Source="{Binding Scan2Thumb}" Stretch="Uniform" Margin="0,8"/>
                                </DockPanel>
                            </Panel>
                        </Border>

                    </Grid>

                    <!-- Slim settings strip -->
                    <StackPanel Orientation="Horizontal" Spacing="18" Margin="2,0,0,0">
                        <StackPanel Spacing="3" IsVisible="{Binding !IsCalibrated}">
                            <TextBlock Text="Scanner DPI" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding DpiText}" Width="80"
                                     ToolTip.Tip="Pixels-per-mm = DPI ÷ 25.4. Needed for absolute scale; leave blank for anisotropy only."/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Coupon (mm)" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding BaselineMmText}" Width="70"
                                     ToolTip.Tip="Centre-to-centre span of the outermost rings. Default 100."/>
                        </StackPanel>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Rings/side" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding GridText}" Width="55"
                                     ToolTip.Tip="Rings per side (grid_n in the model). Default 5."/>
                        </StackPanel>
                    </StackPanel>

                    <Button Content="Analyze both scans" Classes="accent" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" Padding="12,10" FontSize="15"
                            Command="{Binding AnalyzeCommand}"/>
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" Height="4"/>
                    <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" IsVisible="{Binding HasStatus}"
                               Classes="status" Classes.error="{Binding IsError}" HorizontalAlignment="Center"/>

                    <TextBlock TextWrapping="Wrap" FontSize="12" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="The two solid rings mark the coupon's corner — the app uses them to align both scans."/>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

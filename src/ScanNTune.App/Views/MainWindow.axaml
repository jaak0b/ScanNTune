<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ScanNTune.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="720"
        x:Class="ScanNTune.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1000" Height="720"
        Icon="/Assets/ScanNTune.ico"
        Title="ScanNTune">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.caption">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.caption:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
        </Style>
        <Style Selector="Button.caption.close:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E81123"/>
        </Style>
        <Style Selector="Button.caption Path">
            <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="StrokeThickness" Value="1"/>
        </Style>
        <Style Selector="Button.caption.close:pointerover Path">
            <Setter Property="Stroke" Value="#FFFFFF"/>
        </Style>

        <Style Selector="Button.iconbtn">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.iconbtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
        </Style>
        <Style Selector="Button.iconbtn Path">
            <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="Button.iconbtn:pointerover Path">
            <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
    </Window.Styles>

    <DockPanel Margin="{Binding $parent[Window].OffScreenMargin}">

        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
            <Grid Height="40" ColumnDefinitions="*,Auto">

                <Border Grid.Column="0" Background="Transparent"
                        PointerPressed="OnTitleBarPressed" DoubleTapped="OnTitleBarDoubleTapped">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <Image Source="/Assets/icon-256.png" Width="18" Height="18" Margin="0,0,8,0"/>
                        <TextBlock Text="ScanNTune" FontWeight="Bold" FontSize="14"
                                   VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding AppVersion}" FontSize="12" Margin="8,1,0,0"
                                   VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Border IsVisible="{Binding UpdateReady}" Background="{DynamicResource PrimaryBrush}"
                                CornerRadius="10" Padding="9,2" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UpdateStatusText}" FontSize="11" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Classes="iconbtn" Click="OnOpenRepository" ToolTip.Tip="Open on GitHub">
                        <Path Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                              Stretch="Uniform" Width="16" Height="16"/>
                    </Button>
                    <Button Classes="caption" Click="OnMinimize" ToolTip.Tip="Minimize">
                        <Path Data="M0,5 H10"/>
                    </Button>
                    <Button Classes="caption" Click="OnMaximizeRestore" ToolTip.Tip="Maximize">
                        <Path x:Name="MaxIcon" Data="M0,0 H10 V10 H0 Z"/>
                    </Button>
                    <Button Classes="caption close" Click="OnClose" ToolTip.Tip="Close">
                        <Path Data="M0,0 L10,10 M10,0 L0,10"/>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <ContentControl Content="{Binding CurrentPage}"/>
    </DockPanel>

</Window>
